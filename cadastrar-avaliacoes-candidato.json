    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Valida campos obrigatórios\nif (!body.participant?.telefone) {\n  throw new Error('Campo obrigatório ausente: participant.telefone');\n}\nif (!body.scores) {\n  throw new Error('Campo obrigatório ausente: scores');\n}\n\nconst telefone = body.participant.telefone.replace(/\\D/g, '');\nconst exportDate = body.exportDate || null;\n\n// Monta objeto resultado sem os dados de answers (muito volumoso) — inclua se quiser\nconst resultado = JSON.stringify(body);\n\nreturn [{\n  json: {\n    telefone,\n    tipo_avaliacao: 'hogan',\n    export_date: exportDate,\n    resultado\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1960,
        -560
      ],
      "id": "1fe5d7cc-2468-49b0-a89c-e72691f5204f",
      "name": "Preparar Dados"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT telefone FROM candidatos WHERE REGEXP_REPLACE(telefone, '[^0-9]', '', 'g') = '{{ $json.telefone }}' LIMIT 1",
        "options": {}
