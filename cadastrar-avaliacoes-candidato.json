    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst encontrou = items.length > 0 && !!items[0].json?.telefone;\n\nif (!encontrou) {\n  return [{\n    json: {\n      valido: \"false\",\n      telefone: $('Preparar Dados').item.json.telefone,\n      tipo_avaliacao: $('Preparar Dados').item.json.tipo_avaliacao,\n      export_date: $('Preparar Dados').item.json.export_date,\n      resultado: $('Preparar Dados').item.json.resultado\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    valido: \"true\",\n    telefone: items[0].json.telefone,\n    tipo_avaliacao: $('Preparar Dados').item.json.tipo_avaliacao,\n    export_date: $('Preparar Dados').item.json.export_date,\n    resultado: $('Preparar Dados').item.json.resultado\n  }\n}];"
      },
